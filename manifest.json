{
  "manifest_version": 3,
  "name": "SentenceMiner",
  "version": "0.1.0",
  "description": "Capture highlighted subtitles and send to SentenceMiner backend.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SentenceMiner"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}